{
  "name": "splitto-tp",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node --experimental-strip-types src/main.ts",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run tests/unit",
    "test:unit:watch": "vitest tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:contract:consumer": "vitest run --config vitest.contract.config.ts tests/contract/balances.consumer.pact.test.ts",
    "test:contract:provider": "vitest run --config vitest.contract.config.ts tests/contract/balancescontract.config.ts tests/contract/balances.provider.pact.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:coverage": "vitest run --coverage tests/unit",
    "test:mutation": "stryker run",
    "report:e2e": "playwright show-report"
  },
  "dependencies": {
    "express": "^4.21.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@pact-foundation/pact": "^16.4.0",
    "@playwright/test": "^1.48.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.16.0",
    "@types/pg": "^8.11.10",
    "@vitest/coverage-v8": "^4.1.5",
    "testcontainers": "^11.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  }
}
