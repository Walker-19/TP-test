{
  "consumer": {
    "name": "splitto-frontend"
  },
  "interactions": [
    {
      "description": "une requête pour les balances d'un groupe inexistant",
      "providerStates": [
        {
          "name": "aucun groupe inexistant"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/api/groups/inexistant/balances"
      },
      "response": {
        "body": {
          "error": "Group not found"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.error": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          },
          "header": {
            "Content-Type": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "application/json.*"
                }
              ]
            }
          }
        },
        "status": 404
      }
    },
    {
      "description": "une requête pour les balances du groupe group-1",
      "providerStates": [
        {
          "name": "group-1 a 3 membres et 2 dépenses"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/api/groups/group-1/balances"
      },
      "response": {
        "body": {
          "balances": {
            "member-1": 20,
            "member-2": -10,
            "member-3": -10
          },
          "groupId": "group-1",
          "settlements": []
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.balances": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.groupId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.settlements": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          },
          "header": {
            "Content-Type": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "application/json.*"
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.4.0"
    },
    "pactRust": {
      "ffi": "0.5.4",
      "models": "1.3.11"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "splitto-api"
  }
}